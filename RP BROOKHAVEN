local function corner(p,r) local c=Instance.new("UICorner",p); c.CornerRadius=UDim.new(0,r or 8); return c end
local function stroke(p,col,t) local s=Instance.new("UIStroke",p); s.Color=col or C.BORD; s.Thickness=t or 1.5; return s end
local function grad(p,c0,c1,rot) local g=Instance.new("UIGradient",p); g.Color=ColorSequence.new(c0,c1); g.Rotation=rot or 0; return g end
local function tw(o,props,t,sty,dir) pcall(function() TweenSvc:Create(o,TweenInfo.new(t or 0.2,sty or Enum.EasingStyle.Quad,dir or Enum.EasingDirection.Out),props):Play() end) end

local function lbl(par,text,sz,pos,fs,col,xa)
    local l=Instance.new("TextLabel",par); l.Size=sz; l.Position=pos or UDim2.new(0,0,0,0); l.Text=text; l.TextSize=fs or 12
    l.TextColor3=col or C.TEXT; l.BackgroundTransparency=1; l.Font=Enum.Font.GothamBold
    l.TextXAlignment=xa or Enum.TextXAlignment.Center; l.TextWrapped=false; return l
end

local function mkBtn(par,text,sz,pos,bg,fs,tc)
    local b=Instance.new("TextButton",par); b.Size=sz; b.Position=pos or UDim2.new(0,0,0,0); b.Text=text; b.TextSize=fs or 12
    b.Font=Enum.Font.GothamBold; b.TextColor3=tc or C.WHITE; b.BackgroundColor3=bg or C.CARD; b.AutoButtonColor=false; corner(b,9)
    b.MouseEnter:Connect(function() tw(b,{BackgroundTransparency=0.22},0.1) end)
    b.MouseLeave:Connect(function() tw(b,{BackgroundTransparency=0},0.1) end)
    return b
end

local function aBtn(par,text,col,lo,cb,tc)
    local b=mkBtn(par,text,UDim2.new(1,0,0,38),nil,col,12,tc); b.LayoutOrder=lo or 99
    local bs=stroke(b,C.BORD,1)
