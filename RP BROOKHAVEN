    table.insert(nStack,n)
    local function getY() local i=0; for j,v in ipairs(nStack) do if v==n then i=j; break end end; return -(72*(i-1)+80) end
    n.Position=UDim2.new(1,10,1,0)
    tw(n,{Position=UDim2.new(1,-315,1,getY())},0.35,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
    task.delay(dur,function()
        tw(n,{Position=UDim2.new(1,10,1,getY())},0.3); task.wait(0.35)
        for i,v in ipairs(nStack) do if v==n then table.remove(nStack,i); break end end
        for i,v in ipairs(nStack) do tw(v,{Position=UDim2.new(1,-315,1,-(72*(i-1)+80))},0.3) end; n:Destroy()
    end)
end

